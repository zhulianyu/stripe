# Stripe 密钥(从 Stripe Dashboard -> Developers -> API keys 获取)
# 测试环境以 sk_test_ 开头,正式环境以 sk_live_ 开头
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe Webhook 签名密钥(从 Stripe Dashboard -> Developers -> Webhooks 获取)
# 配置 webhook endpoint 后会显示 signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 站点基础 URL(服务端运行时读取,不内联)
# 本地开发:http://localhost:3000
# Cloudflare 部署后:改为 https://pay.sinosoft.online
BASE_URL=http://localhost:3000
